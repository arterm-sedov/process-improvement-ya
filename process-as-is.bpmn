<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_OrderServices" targetNamespace="http://example.com/bpmn/order-services" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.2">
  <bpmn:process id="Process_OrderServices" name="Обработка заказа на услуги" isExecutable="false">
    <bpmn:laneSet id="LaneSet_OrderServices">
      <bpmn:lane id="Lane_Performer" name="Исполнитель">
        <bpmn:flowNodeRef>Task_Performer_ExecuteTask</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Performer_SendResult</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Manager" name="Менеджер">
        <bpmn:flowNodeRef>Task_Manager_AnalyzeRequest</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Manager_DecomposeDescription</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_1a7duyc</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Manager_AdjustServiceList</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Manager_FillServiceList</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Manager_CreateSubtasks</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Manager_WriteSpecification</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Manager_AssignTasks</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Manager_CloseOrder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Manager_CheckPlanFact</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Manager_ReceiveRequest</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_End</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ResultAccepted</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Customer" name="Заказчик">
        <bpmn:flowNodeRef>StartEvent_Start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Customer_FillOrderForm</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_Start" name="Старт">
      <bpmn:outgoing>Flow_Start_To_CustomerFillOrderForm</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="Gateway_ResultAccepted" name="Результат принят?">
      <bpmn:incoming>Flow_ManagerCheckPlanFact_To_ResultAccepted</bpmn:incoming>
      <bpmn:outgoing>Flow_ResultAccepted_Yes_To_ManagerCloseOrder</bpmn:outgoing>
      <bpmn:outgoing>Flow_ResultAccepted_ChangeServices_To_ManagerAdjustServiceList</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="EndEvent_End" name="Конец">
      <bpmn:incoming>Flow_ManagerCloseOrder_To_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_To_CustomerFillOrderForm" sourceRef="StartEvent_Start" targetRef="Task_Customer_FillOrderForm" />
    <bpmn:sequenceFlow id="Flow_CustomerFillOrderForm_To_ManagerReceiveRequest" sourceRef="Task_Customer_FillOrderForm" targetRef="Task_Manager_ReceiveRequest" />
    <bpmn:sequenceFlow id="Flow_ManagerReceiveRequest_To_ManagerAnalyzeRequest" sourceRef="Task_Manager_ReceiveRequest" targetRef="Task_Manager_AnalyzeRequest" />
    <bpmn:sequenceFlow id="Flow_ManagerAnalyzeRequest_To_ManagerDecomposeDescription" sourceRef="Task_Manager_AnalyzeRequest" targetRef="Task_Manager_DecomposeDescription" />
    <bpmn:sequenceFlow id="Flow_ManagerDecomposeDescription_To_ManagerFillServiceList" sourceRef="Gateway_1a7duyc" targetRef="Task_Manager_FillServiceList" />
    <bpmn:sequenceFlow id="Flow_ManagerFillServiceList_To_ManagerCreateSubtasks" sourceRef="Task_Manager_FillServiceList" targetRef="Task_Manager_CreateSubtasks" />
    <bpmn:sequenceFlow id="Flow_ManagerCreateSubtasks_To_ManagerWriteSpecification" sourceRef="Task_Manager_CreateSubtasks" targetRef="Task_Manager_WriteSpecification" />
    <bpmn:sequenceFlow id="Flow_ManagerWriteSpecification_To_ManagerAssignTasks" sourceRef="Task_Manager_WriteSpecification" targetRef="Task_Manager_AssignTasks" />
    <bpmn:sequenceFlow id="Flow_ManagerAssignTasks_To_PerformerExecuteTask" sourceRef="Task_Manager_AssignTasks" targetRef="Task_Performer_ExecuteTask" />
    <bpmn:sequenceFlow id="Flow_PerformerExecuteTask_To_PerformerSendResult" sourceRef="Task_Performer_ExecuteTask" targetRef="Task_Performer_SendResult" />
    <bpmn:sequenceFlow id="Flow_PerformerSendResult_To_ManagerCheckResult" sourceRef="Task_Performer_SendResult" targetRef="Task_Manager_CheckPlanFact" />
    <bpmn:sequenceFlow id="Flow_ManagerCheckPlanFact_To_ResultAccepted" sourceRef="Task_Manager_CheckPlanFact" targetRef="Gateway_ResultAccepted" />
    <bpmn:sequenceFlow id="Flow_ResultAccepted_Yes_To_ManagerCloseOrder" name="Да" sourceRef="Gateway_ResultAccepted" targetRef="Task_Manager_CloseOrder" />
    <bpmn:sequenceFlow id="Flow_ResultAccepted_ChangeServices_To_ManagerAdjustServiceList" name="Нет, нужно изменить состав услуг" sourceRef="Gateway_ResultAccepted" targetRef="Task_Manager_AdjustServiceList" />
    <bpmn:sequenceFlow id="Flow_ManagerCloseOrder_To_End" sourceRef="Task_Manager_CloseOrder" targetRef="EndEvent_End" />
    <bpmn:sequenceFlow id="Flow_ManagerAdjustServiceList_To_ManagerDecomposeDescription" sourceRef="Task_Manager_AdjustServiceList" targetRef="Gateway_1a7duyc" />
    <bpmn:sequenceFlow id="Flow_1snegti" sourceRef="Task_Manager_DecomposeDescription" targetRef="Gateway_1a7duyc" />
    <bpmn:exclusiveGateway id="Gateway_1a7duyc">
      <bpmn:incoming>Flow_ManagerAdjustServiceList_To_ManagerDecomposeDescription</bpmn:incoming>
      <bpmn:incoming>Flow_1snegti</bpmn:incoming>
      <bpmn:outgoing>Flow_ManagerDecomposeDescription_To_ManagerFillServiceList</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_Customer_FillOrderForm" name="Заказчик вручную заполняет форму заказа">
      <bpmn:incoming>Flow_Start_To_CustomerFillOrderForm</bpmn:incoming>
      <bpmn:outgoing>Flow_CustomerFillOrderForm_To_ManagerReceiveRequest</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_Manager_ReceiveRequest" name="Получить заявку">
      <bpmn:incoming>Flow_CustomerFillOrderForm_To_ManagerReceiveRequest</bpmn:incoming>
      <bpmn:outgoing>Flow_ManagerReceiveRequest_To_ManagerAnalyzeRequest</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_Manager_AnalyzeRequest" name="Проанализировать запрос">
      <bpmn:incoming>Flow_ManagerReceiveRequest_To_ManagerAnalyzeRequest</bpmn:incoming>
      <bpmn:outgoing>Flow_ManagerAnalyzeRequest_To_ManagerDecomposeDescription</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_Manager_DecomposeDescription" name="Вручную декомпозировать описание на услуги">
      <bpmn:incoming>Flow_ManagerAnalyzeRequest_To_ManagerDecomposeDescription</bpmn:incoming>
      <bpmn:outgoing>Flow_1snegti</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_Manager_FillServiceList" name="Заполнить перечень услуг для заказчика">
      <bpmn:incoming>Flow_ManagerDecomposeDescription_To_ManagerFillServiceList</bpmn:incoming>
      <bpmn:outgoing>Flow_ManagerFillServiceList_To_ManagerCreateSubtasks</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_Manager_CreateSubtasks" name="Создать подзадачи">
      <bpmn:incoming>Flow_ManagerFillServiceList_To_ManagerCreateSubtasks</bpmn:incoming>
      <bpmn:outgoing>Flow_ManagerCreateSubtasks_To_ManagerWriteSpecification</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_Manager_AdjustServiceList" name="Скорректировать перечень услуг">
      <bpmn:incoming>Flow_ResultAccepted_ChangeServices_To_ManagerAdjustServiceList</bpmn:incoming>
      <bpmn:outgoing>Flow_ManagerAdjustServiceList_To_ManagerDecomposeDescription</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_Manager_WriteSpecification" name="Прописать ТЗ">
      <bpmn:incoming>Flow_ManagerCreateSubtasks_To_ManagerWriteSpecification</bpmn:incoming>
      <bpmn:outgoing>Flow_ManagerWriteSpecification_To_ManagerAssignTasks</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_Manager_AssignTasks" name="Передать задачу исполнителю">
      <bpmn:incoming>Flow_ManagerWriteSpecification_To_ManagerAssignTasks</bpmn:incoming>
      <bpmn:outgoing>Flow_ManagerAssignTasks_To_PerformerExecuteTask</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_Performer_ExecuteTask" name="Выполнить задачу">
      <bpmn:incoming>Flow_ManagerAssignTasks_To_PerformerExecuteTask</bpmn:incoming>
      <bpmn:outgoing>Flow_PerformerExecuteTask_To_PerformerSendResult</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_Performer_SendResult" name="Передать результат менеджеру">
      <bpmn:incoming>Flow_PerformerExecuteTask_To_PerformerSendResult</bpmn:incoming>
      <bpmn:outgoing>Flow_PerformerSendResult_To_ManagerCheckResult</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_Manager_CheckPlanFact" name="Проверить результат, сверить план / факт">
      <bpmn:incoming>Flow_PerformerSendResult_To_ManagerCheckResult</bpmn:incoming>
      <bpmn:outgoing>Flow_ManagerCheckPlanFact_To_ResultAccepted</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_Manager_CloseOrder" name="Закрыть задачу / заказ">
      <bpmn:incoming>Flow_ResultAccepted_Yes_To_ManagerCloseOrder</bpmn:incoming>
      <bpmn:outgoing>Flow_ManagerCloseOrder_To_End</bpmn:outgoing>
    </bpmn:userTask>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_OrderServices">
    <bpmndi:BPMNPlane id="BPMNPlane_OrderServices" bpmnElement="Process_OrderServices">
      <bpmndi:BPMNShape id="Lane_Performer_di" bpmnElement="Lane_Performer" isHorizontal="true">
        <dc:Bounds x="160" y="420" width="1860" height="150" />
