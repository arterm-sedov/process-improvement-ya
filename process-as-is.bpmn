        <dc:Bounds x="1110" y="320" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_1uppnp8_di" bpmnElement="Task_Manager_AssignTasks">
        <dc:Bounds x="1250" y="320" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_1qsxyh2_di" bpmnElement="Task_Performer_ExecuteTask">
        <dc:Bounds x="1360" y="455" width="100" height="80" />
      </bpmndi:BPMNShape>
