<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_ToBe_OrderProcessing" targetNamespace="http://example.com/bpmn/to-be-order-processing" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.2">
  <bpmn:process id="Process_ToBe_OrderProcessing" name="TO-BE: обработка заказа на услуги" isExecutable="false">
    <bpmn:laneSet id="LaneSet_ToBe_OrderProcessing">
      <bpmn:lane id="Lane_Performer" name="Исполнитель">
        <bpmn:flowNodeRef>Task_Performer_ExecuteTaskBySpecification</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Performer_RecordFactAndResult</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_1r7n81p</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Performer_ReworkByComments</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Manager" name="Менеджер">
        <bpmn:flowNodeRef>Task_Manager_AdjustExceptions</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Manager_ReviewDraftAndExceptions</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_1wwqy3d</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Manager_CheckResultByChecklist</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Manager_CloseOrder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ServiceListCorrect</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_End</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ResultAccepted</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_System" name="BPM-система с ИИ-агентом">
        <bpmn:flowNodeRef>Task_System_CreateDraftServiceList</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_System_AutoCreateSubtasks</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_System_InsertSpecificationTemplates</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_System_AssignPerformersByRules</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_System_MonitorSlaAndStatuses</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_System_CheckRequiredFields</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_System_MatchServicesFromCatalog</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_System_UpdatePlanFact</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_DataComplete</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Customer" name="Заказчик">
        <bpmn:flowNodeRef>Gateway_153y4gi</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Customer_FillStructuredOrderForm</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Customer_ClarifyRequestData</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Customer_ConfirmServiceList</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>StartEvent_Start</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_Start" name="Старт">
      <bpmn:outgoing>Flow_Start_To_CustomerFillStructuredOrderForm</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_Customer_FillStructuredOrderForm" name="Заказчик заполняет структурированную форму заказа с типовыми услугами">
      <bpmn:incoming>Flow_Start_To_CustomerFillStructuredOrderForm</bpmn:incoming>
      <bpmn:outgoing>Flow_CustomerFillStructuredOrderForm_To_SystemCheckRequiredFields</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_System_CheckRequiredFields" name="Проверить поля по правилам">
      <bpmn:incoming>Flow_1vya366</bpmn:incoming>
      <bpmn:outgoing>Flow_0fo6e1i</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_DataComplete" name="Данные полные, услуги подобраны?" default="Flow_0ba6e4k">
      <bpmn:incoming>Flow_SystemMatchServicesFromCatalog_To_SystemCreateDraftServiceList</bpmn:incoming>
      <bpmn:outgoing>Flow_DataComplete_No_To_CustomerClarifyRequestData</bpmn:outgoing>
      <bpmn:outgoing>Flow_0ba6e4k</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_Customer_ClarifyRequestData" name="Уточнить данные заявки">
      <bpmn:incoming>Flow_DataComplete_No_To_CustomerClarifyRequestData</bpmn:incoming>
      <bpmn:outgoing>Flow_CustomerClarifyRequestData_To_SystemCheckRequiredFields</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:businessRuleTask id="Task_System_MatchServicesFromCatalog" name="Подобрать услуги из каталога">
      <bpmn:incoming>Flow_0fo6e1i</bpmn:incoming>
      <bpmn:outgoing>Flow_SystemMatchServicesFromCatalog_To_SystemCreateDraftServiceList</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:serviceTask id="Task_System_CreateDraftServiceList" name="Сформировать черновик перечня услуг">
      <bpmn:incoming>Flow_0ba6e4k</bpmn:incoming>
      <bpmn:outgoing>Flow_0lv0i5w</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_Manager_ReviewDraftAndExceptions" name="Проверить черновик и исключения">
      <bpmn:incoming>Flow_SystemCreateDraftServiceList_To_ManagerReviewDraftAndExceptions</bpmn:incoming>
      <bpmn:outgoing>Flow_ManagerReviewDraftAndExceptions_To_ServiceListCorrect</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_ServiceListCorrect" name="Перечень корректен?" default="Flow_ServiceListCorrect_Yes_To_CustomerConfirmServiceList">
      <bpmn:incoming>Flow_ManagerReviewDraftAndExceptions_To_ServiceListCorrect</bpmn:incoming>
      <bpmn:outgoing>Flow_ServiceListCorrect_No_To_ManagerAdjustExceptions</bpmn:outgoing>
      <bpmn:outgoing>Flow_ServiceListCorrect_Yes_To_CustomerConfirmServiceList</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_Manager_AdjustExceptions" name="Скорректировать перечень услуг">
      <bpmn:incoming>Flow_ServiceListCorrect_No_To_ManagerAdjustExceptions</bpmn:incoming>
      <bpmn:outgoing>Flow_ManagerAdjustExceptions_To_SystemCreateDraftServiceList</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_Customer_ConfirmServiceList" name="Подтвердить сформированный  перечень услу">
      <bpmn:incoming>Flow_ServiceListCorrect_Yes_To_CustomerConfirmServiceList</bpmn:incoming>
      <bpmn:outgoing>Flow_CustomerConfirmServiceList_To_SystemAutoCreateSubtasks</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_System_AutoCreateSubtasks" name="Сформировать подзадачи">
      <bpmn:incoming>Flow_CustomerConfirmServiceList_To_SystemAutoCreateSubtasks</bpmn:incoming>
      <bpmn:outgoing>Flow_SystemAutoCreateSubtasks_To_SystemInsertSpecificationTemplates</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_System_InsertSpecificationTemplates" name="Заполнить шаблоны ТЗ">
      <bpmn:incoming>Flow_SystemAutoCreateSubtasks_To_SystemInsertSpecificationTemplates</bpmn:incoming>
      <bpmn:outgoing>Flow_SystemInsertSpecificationTemplates_To_SystemAssignPerformersByRules</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:businessRuleTask id="Task_System_AssignPerformersByRules" name="Назначить исполнителей по правилам">
      <bpmn:incoming>Flow_SystemInsertSpecificationTemplates_To_SystemAssignPerformersByRules</bpmn:incoming>
      <bpmn:outgoing>Flow_SystemAssignPerformersByRules_To_PerformerExecuteTaskBySpecification</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:userTask id="Task_Performer_ExecuteTaskBySpecification" name="Выполнить подзадачи по ТЗ">
      <bpmn:incoming>Flow_SystemAssignPerformersByRules_To_PerformerExecuteTaskBySpecification</bpmn:incoming>
      <bpmn:outgoing>Flow_PerformerExecuteTaskBySpecification_To_PerformerRecordFactAndResult</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_Performer_RecordFactAndResult" name="Зафиксировать факт и результат">
      <bpmn:incoming>Flow_17a8nae</bpmn:incoming>
      <bpmn:outgoing>Flow_PerformerRecordFactAndResult_To_SystemMonitorSlaAndStatuses</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_System_MonitorSlaAndStatuses" name="Контролировать SLA и статусы">
      <bpmn:incoming>Flow_PerformerRecordFactAndResult_To_SystemMonitorSlaAndStatuses</bpmn:incoming>
      <bpmn:outgoing>Flow_SystemMonitorSlaAndStatuses_To_ManagerCheckResultByChecklist</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_Manager_CheckResultByChecklist" name="Проверить результат по чек-листу">
      <bpmn:incoming>Flow_SystemMonitorSlaAndStatuses_To_ManagerCheckResultByChecklist</bpmn:incoming>
      <bpmn:outgoing>Flow_ManagerCheckResultByChecklist_To_ResultAccepted</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_ResultAccepted" name="Результат принят?" default="Flow_ResultAccepted_Yes_To_SystemUpdatePlanFact">
      <bpmn:incoming>Flow_ManagerCheckResultByChecklist_To_ResultAccepted</bpmn:incoming>
      <bpmn:outgoing>Flow_ResultAccepted_Yes_To_SystemUpdatePlanFact</bpmn:outgoing>
      <bpmn:outgoing>Flow_ResultAccepted_No_To_ManagerStartControlledRework</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_System_UpdatePlanFact" name="Обновить данные о заказе">
      <bpmn:incoming>Flow_ResultAccepted_Yes_To_SystemUpdatePlanFact</bpmn:incoming>
      <bpmn:outgoing>Flow_SystemUpdatePlanFact_To_ManagerCloseOrder</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_Manager_CloseOrder" name="Закрыть заказ">
      <bpmn:incoming>Flow_SystemUpdatePlanFact_To_ManagerCloseOrder</bpmn:incoming>
      <bpmn:outgoing>Flow_ManagerCloseOrder_To_End</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_Performer_ReworkByComments" name="Доработать по замечаниям">
      <bpmn:incoming>Flow_ResultAccepted_No_To_ManagerStartControlledRework</bpmn:incoming>
      <bpmn:outgoing>Flow_PerformerReworkByComments_To_PerformerRecordFactAndResult</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndEvent_End" name="Конец">
      <bpmn:incoming>Flow_ManagerCloseOrder_To_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_To_CustomerFillStructuredOrderForm" sourceRef="StartEvent_Start" targetRef="Task_Customer_FillStructuredOrderForm" />
    <bpmn:sequenceFlow id="Flow_CustomerFillStructuredOrderForm_To_SystemCheckRequiredFields" sourceRef="Task_Customer_FillStructuredOrderForm" targetRef="Gateway_153y4gi" />
    <bpmn:sequenceFlow id="Flow_DataComplete_No_To_CustomerClarifyRequestData" name="Нет" sourceRef="Gateway_DataComplete" targetRef="Task_Customer_ClarifyRequestData" />
    <bpmn:sequenceFlow id="Flow_CustomerClarifyRequestData_To_SystemCheckRequiredFields" sourceRef="Task_Customer_ClarifyRequestData" targetRef="Gateway_153y4gi" />
    <bpmn:sequenceFlow id="Flow_SystemMatchServicesFromCatalog_To_SystemCreateDraftServiceList" sourceRef="Task_System_MatchServicesFromCatalog" targetRef="Gateway_DataComplete" />
    <bpmn:sequenceFlow id="Flow_SystemCreateDraftServiceList_To_ManagerReviewDraftAndExceptions" sourceRef="Gateway_1wwqy3d" targetRef="Task_Manager_ReviewDraftAndExceptions" />
    <bpmn:sequenceFlow id="Flow_ManagerReviewDraftAndExceptions_To_ServiceListCorrect" sourceRef="Task_Manager_ReviewDraftAndExceptions" targetRef="Gateway_ServiceListCorrect" />
    <bpmn:sequenceFlow id="Flow_ServiceListCorrect_No_To_ManagerAdjustExceptions" name="Нет" sourceRef="Gateway_ServiceListCorrect" targetRef="Task_Manager_AdjustExceptions" />
    <bpmn:sequenceFlow id="Flow_ManagerAdjustExceptions_To_SystemCreateDraftServiceList" sourceRef="Task_Manager_AdjustExceptions" targetRef="Gateway_1wwqy3d" />
    <bpmn:sequenceFlow id="Flow_ServiceListCorrect_Yes_To_CustomerConfirmServiceList" name="Да" sourceRef="Gateway_ServiceListCorrect" targetRef="Task_Customer_ConfirmServiceList" />
    <bpmn:sequenceFlow id="Flow_CustomerConfirmServiceList_To_SystemAutoCreateSubtasks" sourceRef="Task_Customer_ConfirmServiceList" targetRef="Task_System_AutoCreateSubtasks" />
    <bpmn:sequenceFlow id="Flow_SystemAutoCreateSubtasks_To_SystemInsertSpecificationTemplates" sourceRef="Task_System_AutoCreateSubtasks" targetRef="Task_System_InsertSpecificationTemplates" />
    <bpmn:sequenceFlow id="Flow_SystemInsertSpecificationTemplates_To_SystemAssignPerformersByRules" sourceRef="Task_System_InsertSpecificationTemplates" targetRef="Task_System_AssignPerformersByRules" />
    <bpmn:sequenceFlow id="Flow_SystemAssignPerformersByRules_To_PerformerExecuteTaskBySpecification" sourceRef="Task_System_AssignPerformersByRules" targetRef="Task_Performer_ExecuteTaskBySpecification" />
    <bpmn:sequenceFlow id="Flow_PerformerExecuteTaskBySpecification_To_PerformerRecordFactAndResult" sourceRef="Task_Performer_ExecuteTaskBySpecification" targetRef="Gateway_1r7n81p" />
    <bpmn:sequenceFlow id="Flow_PerformerRecordFactAndResult_To_SystemMonitorSlaAndStatuses" sourceRef="Task_Performer_RecordFactAndResult" targetRef="Task_System_MonitorSlaAndStatuses" />
    <bpmn:sequenceFlow id="Flow_SystemMonitorSlaAndStatuses_To_ManagerCheckResultByChecklist" sourceRef="Task_System_MonitorSlaAndStatuses" targetRef="Task_Manager_CheckResultByChecklist" />
    <bpmn:sequenceFlow id="Flow_ManagerCheckResultByChecklist_To_ResultAccepted" sourceRef="Task_Manager_CheckResultByChecklist" targetRef="Gateway_ResultAccepted" />
    <bpmn:sequenceFlow id="Flow_ResultAccepted_Yes_To_SystemUpdatePlanFact" name="Да" sourceRef="Gateway_ResultAccepted" targetRef="Task_System_UpdatePlanFact" />
    <bpmn:sequenceFlow id="Flow_SystemUpdatePlanFact_To_ManagerCloseOrder" sourceRef="Task_System_UpdatePlanFact" targetRef="Task_Manager_CloseOrder" />
    <bpmn:sequenceFlow id="Flow_ManagerCloseOrder_To_End" sourceRef="Task_Manager_CloseOrder" targetRef="EndEvent_End" />
    <bpmn:sequenceFlow id="Flow_ResultAccepted_No_To_ManagerStartControlledRework" name="Нет, нужна доработка" sourceRef="Gateway_ResultAccepted" targetRef="Task_Performer_ReworkByComments" />
    <bpmn:sequenceFlow id="Flow_PerformerReworkByComments_To_PerformerRecordFactAndResult" sourceRef="Task_Performer_ReworkByComments" targetRef="Gateway_1r7n81p" />
    <bpmn:exclusiveGateway id="Gateway_1wwqy3d">
      <bpmn:incoming>Flow_ManagerAdjustExceptions_To_SystemCreateDraftServiceList</bpmn:incoming>
      <bpmn:incoming>Flow_0lv0i5w</bpmn:incoming>
      <bpmn:outgoing>Flow_SystemCreateDraftServiceList_To_ManagerReviewDraftAndExceptions</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_0lv0i5w" sourceRef="Task_System_CreateDraftServiceList" targetRef="Gateway_1wwqy3d" />
    <bpmn:exclusiveGateway id="Gateway_153y4gi">
      <bpmn:incoming>Flow_CustomerFillStructuredOrderForm_To_SystemCheckRequiredFields</bpmn:incoming>
      <bpmn:incoming>Flow_CustomerClarifyRequestData_To_SystemCheckRequiredFields</bpmn:incoming>
      <bpmn:outgoing>Flow_1vya366</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_1vya366" sourceRef="Gateway_153y4gi" targetRef="Task_System_CheckRequiredFields" />
    <bpmn:sequenceFlow id="Flow_0fo6e1i" sourceRef="Task_System_CheckRequiredFields" targetRef="Task_System_MatchServicesFromCatalog" />
    <bpmn:sequenceFlow id="Flow_0ba6e4k" name="Да" sourceRef="Gateway_DataComplete" targetRef="Task_System_CreateDraftServiceList" />
    <bpmn:exclusiveGateway id="Gateway_1r7n81p">
      <bpmn:incoming>Flow_PerformerExecuteTaskBySpecification_To_PerformerRecordFactAndResult</bpmn:incoming>
      <bpmn:incoming>Flow_PerformerReworkByComments_To_PerformerRecordFactAndResult</bpmn:incoming>
      <bpmn:outgoing>Flow_17a8nae</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_17a8nae" sourceRef="Gateway_1r7n81p" targetRef="Task_Performer_RecordFactAndResult" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_ToBe_OrderProcessing">
