        <dc:Bounds x="430" y="210" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_Start_To_CustomerFillOrderForm_di" bpmnElement="Flow_Start_To_CustomerFillOrderForm">
        <di:waypoint x="256" y="105" />
        <di:waypoint x="300" y="105" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_CustomerFillOrderForm_To_ManagerReceiveRequest_di" bpmnElement="Flow_CustomerFillOrderForm_To_ManagerReceiveRequest">
